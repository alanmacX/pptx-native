    "textbox": {
      "status": "compiles",
      "ooxmlTarget": "p:sp / a:txBody",
      "richRuns": true,
      "bullets": "partial",
      "fields": false,
      "rotation": true,
      "authorIRShape": {
        "type": "text",
        "text": "str|runs[]",
